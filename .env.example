# ─────────────────────────────────────────────────────────────────────────────
# WildfireIQ Kamloops — environment variables
# Copy to `.env` and fill in. Do NOT commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required (Phase 0 verification will fail without these) ──────────────────
# Cesium Ion access token — for World Terrain, OSM Buildings, Bing imagery.
# Sign up free: https://ion.cesium.com/signin/
VITE_CESIUM_ION_TOKEN=

# ── Required by Phase 1 ──────────────────────────────────────────────────────
# NASA FIRMS MAP_KEY — for satellite hotspots (VIIRS/MODIS).
# Free instant signup: https://firms.modaps.eosdis.nasa.gov/api/map_key
FIRMS_MAP_KEY=

# WAQI / AQICN token — for air-quality cross-check + pollutant split.
# Free signup: https://aqicn.org/data-platform/token
WAQI_TOKEN=

# ── Optional (stretch goals) ─────────────────────────────────────────────────
MAPTILER_KEY=
GEE_SERVICE_ACCOUNT_JSON=

# ── App configuration (defaults are fine for local dev) ──────────────────────
VITE_API_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite+aiosqlite:///./data/wildfireiq.db
DUCKDB_PATH=./data/analytics.duckdb

# ── Feature flags ────────────────────────────────────────────────────────────
VITE_ENABLE_TRU_CARBON=false
VITE_ENABLE_NDVI_LAYER=false
