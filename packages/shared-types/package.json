{
  "name": "@wildfireiq/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript types auto-generated from the FastAPI OpenAPI schema. Single source of API contract truth.",
  "type": "module",
  "main": "./api.d.ts",
  "types": "./api.d.ts",
  "exports": {
    ".": {
      "types": "./api.d.ts"
    }
  },
  "scripts": {
    "gen": "openapi-typescript http://localhost:8000/openapi.json -o api.d.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.1"
  }
}
